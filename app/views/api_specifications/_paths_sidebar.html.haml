/ Mobile-friendly paths sidebar (File #2 Mobile)
.flex.flex-col.gap-2.md:gap-1.p-6
  %h2.text-xs.font-semibold.tracking-widest.text-zinc-400.uppercase.px-2.md:px-0.mb-3
    ENDPOINTS (#{revision.endpoints.count})

  - if revision
    - revision.endpoints.order(:path, :method).each do |endpoint|
      = link_to documentation_project_api_specification_api_revision_path(@project, @api_specification, revision, endpoint_id: endpoint.id),
                  class: "block px-4 py-3 hover:bg-zinc-800 rounded-2xl mb-1 group flex items-center gap-3 transition-colors",
                  data: { turbo_frame: "documentation-frame" } do
        %span.method-badge.bg-emerald-900.text-emerald-300.px-3.py-1.text-sm.font-mono.rounded{ class: 'px-2.5' }
          = endpoint.method
        %span.font-medium.truncate.flex-1
          = endpoint.path
        - if endpoint.version != revision.version
          %span.font-medium.text-amber-400{class: 'px-1.5'}
            v#{endpoint.version}
  - else
    .text-zinc-500.text-center.py-12
      No endpoints exist yet.

.flex.min-h-screen.items-center.justify-center.bg-zinc-950
  .max-w-md.w-full
    .bg-zinc-900.border.border-zinc-800.rounded-3xl.shadow-2xl.p-10
      %h1.text-4xl.font-bold.text-center.mb-8.tracking-tight New Project

      = form_with model: @project, class: "space-y-6" do |f|
        .space-y-2
          = f.label :name, "Project name", class: "block text-sm font-medium text-zinc-400"
          = f.text_field :name, autofocus: true, placeholder: "User Service API",
                          class: "w-full bg-zinc-800 border border-zinc-700 rounded-2xl px-5 py-4 focus:outline-none focus:border-blue-500 text-white"

        .space-y-2
          = f.label :description, "Description", class: "block text-sm font-medium text-zinc-400"
          = f.text_area :description, rows: 4, placeholder: "Main public API for customer-facing features",
                          class: "w-full bg-zinc-800 border border-zinc-700 rounded-2xl px-5 py-4 focus:outline-none focus:border-blue-500 text-white"

        .space-y-2
          = f.label :workspace_id, "Workspace", class: "block text-sm font-medium text-zinc-400"
          = f.select :workspace_id, @workspaces.map { |w| [w.name, w.id] }, {},
                     class: "w-full bg-zinc-800 border border-zinc-700 rounded-2xl px-5 py-4 focus:outline-none focus:border-blue-500 text-white"

        = f.submit "Create Project", class: "w-full bg-blue-600 hover:bg-blue-700 py-4 rounded-2xl font-semibold text-white transition-all mt-6 cursor-pointer"
%turbo-frame#flash{ data: { controller: "flash", "flash-duration-value": 5000 } }
  - flash.each do |type, message|
    - next unless message.present?
    .flash-message{ data: { flash_target: "message" }, class: "fixed top-4 left-1/2 transform -translate-x-1/2 z-50 px-4 py-3 rounded shadow-lg #{type == 'notice' ? 'bg-green-100 text-green-800 border border-green-300' : 'bg-red-100 text-red-800 border border-red-300'} max-w-md w-full", role: "alert" }
      %div.flex.justify-between.items-start
        %span
          = message
        %button{ type: "button", class: "ml-4 text-xl leading-none", data: { action: "click->flash#close" }, aria: { label: "Close notification" } } &times;
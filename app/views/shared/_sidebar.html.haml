%nav.bg-zinc-900.border-r.border-zinc-800.w-72.flex-shrink-0.flex.flex-col
  .p-6.border-b.border-zinc-800.flex.items-center.gap-3
    %span.text-3xl 📘
    %h1.font-bold.text-2xl.tracking-tighter Doc Arise

  / Organization Switcher
  .px-6.py-4.border-b.border-zinc-800
    = render "shared/organization_switcher"

  .flex-1.overflow-y-auto.p-4.space-y-8
    / Workspaces
    .space-y-1
      %div.flex.items-center.justify-between.px-3.text-xs.uppercase.tracking-widest.text-zinc-500.mb-2
        %span Workspaces
        = link_to new_workspace_path, class: "text-blue-400 hover:text-blue-500 text-xs flex items-center gap-1", disabled: authenticated? do
          + New
      - if authenticated?
        - Current.user.workspaces.each do |project|
          = link_to project, class: "flex items-center gap-3 px-4 py-2.5 rounded-2xl hover:bg-zinc-800 text-sm" do
            %span.text-blue-400 📄
            %span
              = project.name

    / Projects
    .space-y-1
      %div.px-3.text-xs.uppercase.tracking-widest.text-zinc-500.mb-2 Projects
      - if authenticated?
        - Current.user.workspaces.flat_map(&:projects).each do |project|
          = link_to project, class: "flex items-center gap-3 px-4 py-2.5 rounded-2xl hover:bg-zinc-800 text-sm" do
            %span.text-blue-400 📄
            %span
              = project.name
      - else
        .px-4.py-3.text-sm.text-zinc-500
          Please sign in to see your projects.

  / Bottom
  .p-4.border-t.border-zinc-800
    - if authenticated?
      = link_to session_path, method: :delete, class: "flex items-center gap-3 px-4 py-3 text-red-400 hover:bg-zinc-800 rounded-2xl text-sm" do
        ⬅️ Sign out
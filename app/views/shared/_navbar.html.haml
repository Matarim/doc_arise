.bg-zinc-900.border-b.border-zinc-800.px-8.py-4.flex.items-center.justify-between
  .flex.items-center.gap-6.flex-1
    %input{ type: "text", placeholder: "Search endpoints, schemas, projects…",
            class: "bg-zinc-800 border border-zinc-700 focus:border-blue-500 rounded-3xl px-5 py-3 w-96 text-sm focus:outline-none" }

  .flex.items-center.gap-8
    / New Project Button
    = link_to new_project_path, class: "flex items-center gap-2 bg-blue-600 hover:bg-blue-700 px-6 py-2 rounded-2xl font-semibold text-sm", disabled: true, aria_disabled: true do
      %span.text-lg +
      New Project

    / User Menu
    - if authenticated?
      .relative.group
        %button.flex.items-center.gap-3
          %img{ src: "https://i.pravatar.cc/32?u=#{Current.user&.id}", class: "w-8 h-8 rounded-2xl" }
          %span.font-medium.text-sm
            = Current.user&.first_name || Current.user&.email_address&.split("@")&.first

        .hidden.group-hover:block.absolute.right-0.mt-2.w-64.bg-zinc-900.border.border-zinc-700.rounded-3xl.shadow-2xl.py-2.z-50
          .px-6.py-4.border-b.border-zinc-700
            .text-xs.text-zinc-400
              Signed in as
            .font-medium
              = Current.user&.email_address
          = link_to "#", class: "block px-6 py-3 hover:bg-zinc-800" do
            Profile & Settings
          = link_to session_path, method: :delete, class: "block px-6 py-3 text-red-400 hover:bg-zinc-800" do
            Sign out
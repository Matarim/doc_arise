.bg-zinc-900.border-b.border-zinc-800.px-4.md:px-8.py-4.flex.items-center.gap-4
  / Hamburger – opens Tailwind Elements drawer
  %button.lg:hidden.px-4.py-3.bg-zinc-800.hover:bg-zinc-700.text-white.rounded-2xl.flex.items-center.gap-2{command: "show-modal", commandfor: "mobileAppSidebar"}
    %span.text-3xl ☰

  / Search bar (exactly as requested – stays in navbar)
  %input.hidden.lg:block{type: "text", placeholder: "Search endpoints, schemas, projects…", class: "bg-zinc-800 border border-zinc-700 focus:border-blue-500 rounded-3xl px-5 py-3 flex-1 max-w-md text-sm focus:outline-none"}

  / Desktop-only actions
  .hidden.lg:flex.items-center.gap-8.ml-auto
    = link_to new_project_path, class: "flex items-center gap-2 bg-blue-600 hover:bg-blue-700 px-6 py-2 rounded-2xl font-semibold text-sm" do
      %span.text-lg +
      New Project

%input.flex.lg:hidden{type: "text", placeholder: "Search endpoints, schemas, projects…", class: "mt-2 mx-auto custom-form-field bg-zinc-800 border border-zinc-700 focus:border-blue-500 rounded-3xl px-5 py-3 w-full max-w-sm text-sm focus:outline-none"}

/ Responsive documentation content (File #2 Mobile)
%turbo-frame#documentation-frame
  - if @selected_endpoint
    = render "api_revisions/endpoint_details", endpoint: @selected_endpoint
  - else
    .bg-zinc-950.border.border-zinc-700.rounded-3xl.p-8.md:p-12.text-center
      .mx-auto.w-16.h-16.flex.items-center.justify-center.text-4xl.mb-6
        📡
      %h3.text-2xl.font-light.text-zinc-300.mb-3
        Select an endpoint from the sidebar
      %p.text-zinc-400.max-w-xs.mx-auto
        The full interactive documentation for the chosen path will appear here.

  / Mobile "jump to sidebar" hint (only visible on small screens)
  .lg:hidden.mt-8.flex.justify-center
    %button.px-5.py-3.bg-zinc-800.hover:bg-zinc-700.rounded-2xl.text-sm.font-medium.flex.items-center.gap-2{ data: { action: "click->spec-mode#toggleMobileDrawer" }}
      ← Back to endpoints list

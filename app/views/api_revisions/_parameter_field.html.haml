.parameter-row.bg-zinc-950.border.border-zinc-700.rounded-2xl.p-6.flex.flex-col.gap-2.md:gap-4
  .grid.grid-cols-12.gap-2
    .col-span-5.flex.items-center.gap-4
      .flex.items-center.gap-2
        = f.check_box "parameters[][required]", class: "w-4 h-4 accent-emerald-500"
        %span.text-sm Required
      .flex.items-center.gap-2
        = f.check_box "parameters[][nullable]", class: "w-4 h-4 accent-emerald-500"
        %span.text-sm Nullable
    .col-span-7.flex.justify-end.mt-2
      %button{ type: "button", data: { action: "manual-editor#removeParameter" },
               class: "text-red-400 hover:text-red-300 cursor-pointer" }
        Remove

  .grid.grid-cols-12.gap-2
    .col-span-7.md:col-span-3
      = f.select "parameters[][in_location]", %w[query path header cookie], {},
                  class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white"
    .col-span-12.md:col-span-5
      = f.text_field "parameters[][name]", placeholder: "parameter_name",
                     class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white font-mono"
    .col-span-12.md:col-span-4
      = f.select "parameters[][type]", %w[string integer number boolean array object enum dictionary], {},
                 class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white cursor-pointer",
                 data: { action: "change->manual-editor#updateParameterType" }

  .grid.grid-cols-12.gap-2
    .col-span-12.md:col-span-6
      = f.select "parameters[][format]", %w[date-time date time email byte uuid uri hostname ipv4 ipv6 password int32 int64 float double regex], { prompt: "Select Format" },
                 class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white", style: "box-sizing: border-box;"
    .col-span-12.md:col-span-6
      = f.text_field "parameters[][default]", placeholder: "Default value (optional)",
                     class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white"

  / Conditional validation fields
  .string-group.grid.grid-cols-12.gap-2
    .col-span-6.md:col-span-4
      = f.number_field "parameters[][min_length]", placeholder: "minLength",
                     class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white"
    .col-span-6.md:col-span-4
      = f.number_field "parameters[][max_length]", placeholder: "maxLength",
                     class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white"
    .col-span-12.md:col-span-4
      = f.text_field "parameters[][pattern]", placeholder: "^[A-Z0-9]+$",
                     class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white font-mono text-sm"

  .number-group.hidden.grid.grid-cols-12.gap-2
    .col-span-12.md:col-span-6
      = f.number_field "parameters[][minimum]", placeholder: "minimum",
                     class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white"
    .col-span-12.md:col-span-6
      = f.number_field "parameters[][maximum]", placeholder: "maximum",
                     class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white"

  .gap-2
    = f.text_field "parameters[][description]", placeholder: "Description of this parameter",
                   class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white"
  .gap-2
    = f.text_field "parameters[][example]", placeholder: "Example value for this parameter",
                   class: "custom-form-field w-full bg-zinc-800 border border-zinc-700 rounded-2xl focus:outline-none focus:border-emerald-500 text-white"
.max-w-7xl.mx-auto.p-8
  - if @api_revision.endpoints.any?
    .space-y-12
      - @api_revision.endpoints.order(:path, :method).each do |ep|
        .bg-zinc-900.border.border-zinc-700.rounded-3xl.p-8{ id: "endpoint-#{ep.id}" }
          %h3.flex.items-center.gap-3.text-2xl.font-semibold
            %span.method-badge.bg-emerald-900.text-emerald-300.px-4.py-1.text-sm.font-mono
              = ep.method
            %span.font-mono
              = ep.path
            - if ep.deprecated
              %span.px-3.py-1.text-xs.bg-red-900.text-red-300.rounded-full Deprecated
          %p.text-zinc-400.mt-2
            = ep.summary
          %p.text-zinc-500
            = ep.description.presence || "No description"

          = render "api_revisions/endpoint_details", endpoint: ep
  - else
    .text-center.py-20
      %div.mx-auto.w-20.h-20.bg-zinc-800.rounded-3xl.flex.items-center.justify-center.mb-6.text-4xl
        📋
      %p.text-zinc-400.text-xl No endpoints yet